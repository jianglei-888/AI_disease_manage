<view class="container">
  <!-- 用户封面 -->
  <view class="cover card card--grain">
    <view class="cover__row">
      <view class="cover__avatar">
        <text class="serif cover__avatar-txt">{{userInitial}}</text>
      </view>
      <view class="cover__meta">
        <text class="eyebrow">FILE  /  个人档案</text>
        <text class="serif cover__name">{{userInfo && userInfo.username ? userInfo.username : '未登录'}}</text>
        <text class="cover__email mono">{{userInfo && userInfo.email ? userInfo.email : '—'}}</text>
      </view>
    </view>
    <view class="cover__stats">
      <view class="cover__stat">
        <text class="numeral numeral--md mono">12</text>
        <text class="eyebrow">本月记录</text>
      </view>
      <view class="cover__stat-divider"></view>
      <view class="cover__stat">
        <text class="numeral numeral--md mono">5</text>
        <text class="eyebrow">AI 咨询</text>
      </view>
      <view class="cover__stat-divider"></view>
      <view class="cover__stat">
        <text class="numeral numeral--md mono">V 0.1</text>
        <text class="eyebrow">当前版本</text>
      </view>
    </view>
  </view>

  <!-- 功能 1 -->
  <view class="section">
    <text class="eyebrow section__head">FILE  /  我的资料</text>
    <view class="list card">
      <view class="list__item" bindtap="handlePersonalInfo">
        <view class="list__icon list__icon--warm serif">A</view>
        <view class="list__col">
          <text class="serif list__title">个人信息</text>
          <text class="list__sub">完善姓名 / 性别 / 用药史</text>
        </view>
        <text class="list__arr">›</text>
      </view>
      <view class="list__item" bindtap="handleHistory">
        <view class="list__icon list__icon--cool serif">H</view>
        <view class="list__col">
          <text class="serif list__title">历史记录</text>
          <text class="list__sub">回看每一次测量</text>
        </view>
        <text class="list__arr">›</text>
      </view>
      <view class="list__item list__item--last" bindtap="handleNotification">
        <view class="list__icon list__icon--alert serif">N</view>
        <view class="list__col">
          <text class="serif list__title">通知设置</text>
          <text class="list__sub">提醒 / 推送偏好</text>
        </view>
        <text class="list__arr">›</text>
      </view>
    </view>
  </view>

  <!-- 功能 2 -->
  <view class="section">
    <text class="eyebrow section__head">ABOUT  /  关于</text>
    <view class="list card">
      <view class="list__item" bindtap="handleDisclaimer">
        <view class="list__icon list__icon--ink serif">D</view>
        <view class="list__col">
          <text class="serif list__title">免责声明</text>
          <text class="list__sub">本应用建议不能替代医生</text>
        </view>
        <text class="list__arr">›</text>
      </view>
      <view class="list__item" bindtap="handlePrivacy">
        <view class="list__icon list__icon--ink serif">P</view>
        <view class="list__col">
          <text class="serif list__title">隐私政策</text>
          <text class="list__sub">我们如何处理你的数据</text>
        </view>
        <text class="list__arr">›</text>
      </view>
      <view class="list__item list__item--last" bindtap="handleAbout">
        <view class="list__icon list__icon--ink serif">i</view>
        <view class="list__col">
          <text class="serif list__title">关于我们</text>
          <text class="list__sub">VITALS · MIDNIGHT CLINIC</text>
        </view>
        <text class="list__arr">›</text>
      </view>
    </view>
  </view>

  <!-- 退出 -->
  <button class="btn btn--danger" bindtap="handleLogout" style="margin-top: 48rpx;">退 出 登 录</button>

  <view class="footnote">
    <text class="eyebrow">© 2025  VITALS  ·  MIDNIGHT CLINIC</text>
  </view>
</view>
