/* === 个人中心 === */
.container { background: var(--bg-base); }

.cover {
  margin-top: 16rpx;
  padding: 40rpx 32rpx;
}
.cover__row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.cover__avatar {
  width: 128rpx; height: 128rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--accent-warm) 0%, var(--accent-warm-2) 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232,168,124,.25);
}
.cover__avatar-txt {
  font-size: 64rpx;
  color: var(--ink-inverse);
  font-weight: 600;
  font-style: italic;
}
.cover__meta { flex: 1; }
.cover__name {
  display: block;
  font-size: 44rpx;
  color: var(--ink-strong);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
}
.cover__email {
  display: block;
  font-size: 22rpx;
  color: var(--ink-dim);
  letter-spacing: 1rpx;
  margin-top: 6rpx;
}

.cover__stats {
  display: flex;
  align-items: center;
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--line-soft);
}
.cover__stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.cover__stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--line);
}

.section { margin-top: 36rpx; }
.section__head {
  display: block;
  margin: 0 8rpx 14rpx;
  color: var(--ink-dim);
}

.list {
  padding: 0;
  overflow: hidden;
}
.list__item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--line-soft);
  transition: background .15s ease;
}
.list__item:active { background: var(--bg-elevated); }
.list__item--last { border-bottom: none; }
.list__icon {
  width: 64rpx; height: 64rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600;
  flex-shrink: 0;
}
.list__icon--warm  { background: rgba(232,168,124,.12); color: var(--accent-warm); border: 1rpx solid rgba(232,168,124,.3); }
.list__icon--cool  { background: rgba(125,211,192,.12); color: var(--accent-cool); border: 1rpx solid rgba(125,211,192,.3); }
.list__icon--alert { background: rgba(224,122,95,.12);  color: var(--alert);        border: 1rpx solid rgba(224,122,95,.3);  }
.list__icon--ink   { background: rgba(255,255,255,.04); color: var(--ink-mid);      border: 1rpx solid var(--line);            }
.list__col { flex: 1; }
.list__title {
  display: block;
  font-size: 30rpx;
  color: var(--ink-strong);
  letter-spacing: 2rpx;
}
.list__sub {
  display: block;
  font-size: 22rpx;
  color: var(--ink-dim);
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}
.list__arr {
  font-size: 32rpx;
  color: var(--ink-dim);
  font-weight: 300;
}

.footnote { text-align: center; margin-top: 32rpx; }
