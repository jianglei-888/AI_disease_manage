<view class="container">
  <view class="login-form">
    <view class="title">登录</view>
    
    <view class="form-item">
      <view class="label">邮箱</view>
      <input 
        class="input" 
        placeholder="请输入邮箱" 
        bindinput="bindEmailInput"
        value="{{email}}"
      />
    </view>
    
    <view class="form-item">
      <view class="label">密码</view>
      <input 
        class="input" 
        placeholder="请输入密码" 
        password 
        bindinput="bindPasswordInput"
        value="{{password}}"
      />
    </view>
    
    <view class="remember-container">
      <checkbox class="checkbox" checked="{{remember}}" bindchange="bindRememberChange" />
      <text class="remember-text">记住密码</text>
    </view>
    
    <button class="login-btn" bindtap="handleLogin">登录</button>
    
    <view class="links">
      <navigator url="/pages/register/register" class="link">注册</navigator>
      <text class="divider">|</text>
      <text class="link" bindtap="handleForgotPassword">忘记密码</text>
    </view>
  </view>
</view>