/* === personal-info === */
.container { background: var(--bg-base); }

.masthead { padding: 8rpx; }
.masthead__row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.masthead__title {
  font-size: 56rpx;
  color: var(--ink-strong);
  margin-top: 8rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  line-height: 1;
}
.masthead__hint { color: var(--ink-dim); }
.masthead__sub {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--ink-mid);
  line-height: 1.6;
}

.form { margin-top: 32rpx; }
.form__row { margin-bottom: 28rpx; }
.form__label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--ink-dim);
}
.form__input {
  font-family: var(--font-mono);
  font-size: 30rpx;
  color: var(--ink-strong);
  letter-spacing: 2rpx;
}

.gender { display: flex; gap: 16rpx; }
.gender__opt {
  flex: 1;
  height: 96rpx;
  border: 1rpx solid var(--line);
  background: var(--bg-card-soft);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  transition: all .2s ease;
}
.gender__opt.is-on {
  border-color: var(--accent-warm);
  background: rgba(232,168,124,.12);
  box-shadow: 0 4rpx 16rpx rgba(232,168,124,.18);
}
.gender__txt {
  font-size: 30rpx;
  letter-spacing: 4rpx;
  color: var(--ink-strong);
}

.field--textarea {
  height: auto;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  align-items: flex-start;
}
.form__textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink-strong);
  background: transparent;
  border: none;
  outline: none;
}
