.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 20rpx;
  display: flex;
  max-width: 80%;
  align-items: flex-end;
}

.user-message {
  display: flex;
  flex-direction: row-reverse;
  justify-content: flex-start;
  margin-left: auto;
  text-align: right;
  width: 100%;
}

.ai-message {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  margin-right: auto;
  text-align: left;
  width: 100%;
}

/* 头像样式 */
.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  margin: 0 10rpx;
}

.message-bubble {
  padding: 15rpx 20rpx;
  border-radius: 20rpx;
  position: relative;
}

.user-message .message-bubble {
  background-color: #4facfe;
  color: white;
  border-bottom-left-radius: 5rpx;
  border-bottom-right-radius: 20rpx;
}

.ai-message .message-bubble {
  background-color: white;
  color: #333;
  border-bottom-left-radius: 5rpx;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
}

.message-content {
  font-size: 26rpx;
  line-height: 1.4;
  word-break: break-word;
}

.message-time {
  font-size: 18rpx;
  opacity: 0.7;
  margin-top: 5rpx;
  display: block;
  text-align: right;
  margin-right: 10rpx;
  color: #666;
}

.user-message .message-time {
  text-align: right;
  margin-right: 10rpx;
  color: rgba(255, 255, 255, 0.7);
}

.ai-message .message-time {
  text-align: left;
  margin-left: 10rpx;
  color: #666;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-top: 2rpx solid #e5e5e5;
  align-items: center;
}

.input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  margin-right: 15rpx;
}

.input-area .send-btn {
  width: 120rpx !important;
  height: 80rpx !important;
  background-color: #4facfe !important;
  color: rgb(255, 255, 255) !important;
  font-size: 28rpx !important;
  border-radius: 40rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border: none !important;
  padding: 0 !important;
}

.input-area .send-btn[disabled] {
  background-color: #cccccc !important;
}