# ============ 服务基础 ============
APP_PORT=8001
APP_HOST=0.0.0.0
APP_ENV=dev
APP_DEBUG=true

# ============ 数据库（必填）============
# 必填。示例格式（请替换为实际 DSN）：
# DATABASE_URL=mysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DBNAME>?charset=utf8mb4
DATABASE_URL=

# ============ JWT ============
SECRET_KEY=please-change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ LLM（通义千问兼容模式，也支持 deepseek/openai 等） ============
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen3.6-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 嵌入模型（阿里 DashScope 兼容模式，text-embedding-v3，dim=1024 对齐 Milvus） ============
EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
EMBEDDING_DIM=1024

# ============ Milvus ============
MILVUS_URI=http://localhost:19530
MILVUS_DB=medical_RAG
MILVUS_COLLECTION=medical_knowledge
MILVUS_TOKEN=

# ============ 文档切分 ============
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ============ SMTP 邮件 ============
# 留空时邮件发送功能会被禁用（LangGraph email 节点返回"邮件未发送"提示）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=511426638@qq.com
SMTP_USERNAME=511426638@qq.com
SMTP_PASSWORD=your-smtp-authorization-code

# ============ MCP（可选，独立进程） ============
MCP_SERVER_URL=http://localhost:8888