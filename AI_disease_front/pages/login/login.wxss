/* === 登录页 — Midnight Clinic === */

.container {
  min-height: 100vh;
  background: var(--bg-base);
}

/* 顶部刊号 */
.masthead {
  margin-bottom: 48rpx;
}
.masthead__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 主视觉 — 错位排版 */
.hero {
  position: relative;
  display: flex;
  align-items: flex-start;
  margin: 24rpx 0 64rpx;
  min-height: 380rpx;
}
.hero__bignum {
  font-family: var(--font-serif);
  font-size: 320rpx;
  line-height: .82;
  color: var(--accent-warm);
  font-weight: 500;
  margin-right: 32rpx;
  font-style: italic;
  text-shadow: 0 4rpx 32rpx rgba(232,168,124,.25);
  letter-spacing: -8rpx;
}
.hero__copy {
  flex: 1;
  padding-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.hero__sub { color: var(--ink-dim); }
.hero__title {
  font-family: var(--font-serif);
  font-size: 72rpx;
  line-height: 1.05;
  color: var(--ink-strong);
  font-weight: 500;
  letter-spacing: 4rpx;
  white-space: pre-line;
  text-shadow: 0 2rpx 0 var(--line-soft);
}
.hero__desc {
  font-family: var(--font-serif);
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-mid);
  white-space: pre-line;
  margin-top: 8rpx;
  border-left: 2rpx solid var(--accent-warm);
  padding-left: 18rpx;
}

/* 表单 */
.form { margin-top: 16rpx; }
.form__row { margin-bottom: 32rpx; }
.form__label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--ink-dim);
}
.form__input {
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  color: var(--ink-strong);
  font-size: 30rpx;
}

.form__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8rpx 0 40rpx;
}
.remember {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.remember__box {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid var(--line);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card-soft);
  transition: all .2s ease;
}
.remember__box.is-on {
  background: var(--accent-warm);
  border-color: var(--accent-warm);
}
.remember__mark {
  color: var(--ink-inverse);
  font-size: 22rpx;
  font-weight: 700;
}
.remember__text {
  font-size: 24rpx;
  color: var(--ink-mid);
  letter-spacing: 2rpx;
}
.forget {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-dim);
  letter-spacing: 2rpx;
}

.links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14rpx;
  margin-top: 36rpx;
}
.links__hint {
  font-size: 24rpx;
  color: var(--ink-dim);
}
.links__action {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--accent-warm);
  letter-spacing: 2rpx;
}

.footnote {
  margin-top: 96rpx;
  text-align: center;
}
