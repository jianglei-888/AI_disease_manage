.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: #f5f5f5;
  padding: 0 30rpx;
}

.login-form {
  width: 100%;
  max-width: 500rpx;
  background-color: white;
  padding: 60rpx;
  border-radius: 20rpx;
  box-shadow: 0 0 20rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #4facfe;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.remember-container {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.checkbox {
  margin-right: 10rpx;
  transform: scale(1.2);
}

.remember-text {
  font-size: 26rpx;
  color: #666;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #4facfe;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.links {
  display: flex;
  justify-content: center;
  align-items: center;
}

.link {
  font-size: 26rpx;
  color: #4facfe;
  margin: 0 20rpx;
}

.divider {
  color: #999;
  margin: 0 10rpx;
}