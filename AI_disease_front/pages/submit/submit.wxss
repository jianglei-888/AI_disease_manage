/* === 录入页 === */
.container { padding-top: 16rpx; }

.masthead { padding: 8rpx; }
.masthead__row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.masthead__title {
  font-size: 64rpx;
  color: var(--ink-strong);
  letter-spacing: 8rpx;
  margin-top: 8rpx;
  line-height: 1;
  font-weight: 500;
}
.masthead__seq {
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}
.masthead__seq-num {
  font-size: 64rpx;
  color: var(--accent-warm);
  font-weight: 600;
  font-style: italic;
}

.card { margin-top: 24rpx; }
.card__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

/* 血压输入 */
.bp {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 8rpx 0 4rpx;
}
.bp__cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.bp__num {
  display: flex;
  align-items: baseline;
  border-bottom: 1rpx solid var(--line);
  padding: 8rpx 0 12rpx;
}
.bp__input {
  flex: 1;
  font-size: 96rpx;
  color: var(--ink-strong);
  height: 110rpx;
  line-height: 110rpx;
}
.bp__unit {
  font-size: 20rpx;
  color: var(--ink-dim);
  letter-spacing: 2rpx;
}
.bp__divider {
  font-size: 80rpx;
  color: var(--ink-dim);
  font-weight: 200;
  margin: 0 12rpx;
  padding-bottom: 8rpx;
}

/* 血糖 */
.bs { padding: 16rpx 0 4rpx; }
.bs__num-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--line);
  padding: 8rpx 0 12rpx;
}
.bs__input {
  flex: 1;
  font-size: 120rpx !important;
  color: var(--accent-warm);
  height: 140rpx;
  line-height: 140rpx;
  font-weight: 600;
}
.bs__unit {
  font-size: 22rpx;
  color: var(--ink-dim);
  letter-spacing: 2rpx;
}

/* 时间 */
.time-card { padding: 28rpx 32rpx; }
.time-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.time-card__txt {
  display: block;
  margin-top: 10rpx;
  font-size: 36rpx;
  color: var(--ink-strong);
  letter-spacing: 2rpx;
}
.time-card__arr {
  font-size: 32rpx;
  color: var(--accent-warm);
}

/* 状态 */
.status {
  display: flex;
  align-items: stretch;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
  gap: 16rpx;
}
.status__bar {
  width: 4rpx;
  background: var(--accent-warm);
  border-radius: 2rpx;
  flex-shrink: 0;
}
.status__txt {
  font-size: 24rpx;
  color: var(--ink-mid);
  line-height: 1.6;
  white-space: pre-line;
}

.submit-btn { margin-top: 36rpx; }

.footnote { text-align: center; margin-top: 32rpx; }
