/* === 聊天页 === */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-base);
  padding: 0 0 24rpx;
}

/* 状态条 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.status-bar__row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.status-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--ink-dim);
  box-shadow: 0 0 0 4rpx rgba(110,106,98,.18);
}
.status-dot.is-on {
  background: var(--accent-cool);
  box-shadow: 0 0 0 4rpx rgba(125,211,192,.18), 0 0 12rpx var(--accent-cool);
  animation: pulse 1.6s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: .55; }
}

/* 消息 */
.message-list {
  flex: 1;
  padding: 24rpx 32rpx 16rpx;
  height: 0;
}

.msg {
  display: flex;
  align-items: flex-start;
  margin-bottom: 36rpx;
  gap: 18rpx;
}
.msg--user { justify-content: flex-end; }
.msg__col { flex: 1; max-width: 76%; display: flex; flex-direction: column; gap: 10rpx; }
.msg__col--right { align-items: flex-end; }

.msg__avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600;
  flex-shrink: 0;
}
.msg__avatar--ai {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  color: var(--accent-warm);
}
.msg__avatar--user {
  background: var(--accent-warm);
  color: var(--ink-inverse);
}

.msg__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 20rpx;
  color: var(--ink-dim);
}
.msg__meta--right { justify-content: flex-end; }
.msg__name {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--ink-mid);
}
.msg__time {
  font-size: 18rpx;
  letter-spacing: 1rpx;
  color: var(--ink-dim);
}

.msg__bubble {
  position: relative;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  line-height: 1.6;
  word-break: break-word;
}
.msg__bubble--ai {
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  color: var(--ink-strong);
  border-top-left-radius: 6rpx;
}
.msg__bubble--ai .msg__content {
  font-size: 28rpx;
  letter-spacing: 1rpx;
}
.msg__quote {
  position: absolute;
  left: 0; top: 24rpx; bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--accent-warm), var(--accent-warm-2));
  border-radius: 2rpx;
}

.msg__bubble--user {
  background: var(--accent-warm);
  color: var(--ink-inverse);
  border-top-right-radius: 6rpx;
}
.msg__bubble--user .msg__content {
  font-size: 28rpx;
  letter-spacing: 1rpx;
  color: var(--ink-inverse);
}

/* 加载 */
.typing {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  border-top-left-radius: 6rpx;
  width: fit-content;
}
.typing__dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: var(--ink-mid);
  animation: typing 1.2s ease-in-out infinite;
}
.typing__dot:nth-child(2) { animation-delay: .2s; }
.typing__dot:nth-child(3) { animation-delay: .4s; }
@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: .4; }
  30%           { transform: translateY(-6rpx); opacity: 1; }
}
.typing__txt {
  margin-left: 12rpx;
  font-size: 20rpx;
  color: var(--ink-dim);
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 80rpx 0 0;
  gap: 12rpx;
}
.empty__big {
  font-size: 56rpx;
  color: var(--ink-strong);
  letter-spacing: 6rpx;
  font-weight: 500;
  line-height: 1.3;
}
.empty__hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--ink-mid);
  line-height: 1.7;
}
.empty__chips {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}
.empty__chip {
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--ink-strong);
  background: var(--bg-card);
  letter-spacing: 1rpx;
}
.empty__chip:active { background: var(--bg-elevated); }

/* 输入区 */
.composer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx 24rpx;
  background: linear-gradient(180deg, transparent 0%, var(--bg-base) 30%);
}
.composer__field {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 0 24rpx;
  height: 88rpx;
  transition: border-color .2s ease;
}
.composer__prompt {
  font-size: 28rpx;
  color: var(--accent-warm);
  margin-right: 12rpx;
  font-weight: 700;
}
.composer__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink-strong);
  background: transparent;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
}

.composer__send {
  width: 120rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card-soft);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  transition: all .2s ease;
}
.composer__send.is-on {
  background: var(--accent-warm);
  border-color: var(--accent-warm);
  box-shadow: 0 4rpx 16rpx rgba(232,168,124,.3);
}
.composer__send.is-on .composer__send-txt { color: var(--ink-inverse); font-weight: 700; }
.composer__send-txt {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--ink-dim);
}
