<view class="container">
  <view class="masthead">
    <view class="masthead__row">
      <view>
        <text class="eyebrow">EDIT  /  档案编辑</text>
        <view class="masthead__title serif">关于你</view>
      </view>
      <text class="masthead__hint eyebrow">FORM  03</text>
    </view>
    <view class="hairline hairline--dashed" style="margin-top: 24rpx;"></view>
    <text class="masthead__sub">这些信息会帮助 AI 给出更贴合的建议。</text>
  </view>

  <view class="form">
    <view class="form__row">
      <text class="form__label eyebrow">NAME  /  姓名</text>
      <view class="field">
        <input class="form__input" placeholder="请输入姓名" placeholder-style="color:#6E6A62; letter-spacing:2rpx;"
          value="{{personalInfo.name}}" bindinput="bindNameInput" />
      </view>
    </view>

    <view class="form__row">
      <text class="form__label eyebrow">GENDER  /  性别</text>
      <view class="gender">
        <view class="gender__opt {{personalInfo.gender === '男' ? 'is-on' : ''}}" bindtap="handleGenderSelect" data-gender="男">
          <text class="serif gender__txt">男 · M</text>
        </view>
        <view class="gender__opt {{personalInfo.gender === '女' ? 'is-on' : ''}}" bindtap="handleGenderSelect" data-gender="女">
          <text class="serif gender__txt">女 · F</text>
        </view>
      </view>
    </view>

    <view class="form__row">
      <text class="form__label eyebrow">AGE  /  年龄</text>
      <view class="field">
        <input class="form__input mono" type="number" placeholder="如 58" placeholder-style="color:#6E6A62; letter-spacing:2rpx;"
          value="{{personalInfo.age}}" bindinput="bindAgeInput" />
        <text class="unit">岁</text>
      </view>
    </view>

    <view class="form__row">
      <text class="form__label eyebrow">MEDICATION  /  用药历史</text>
      <view class="field field--textarea">
        <textarea class="form__textarea serif" placeholder="如：二甲双胍 0.5g bid（已用 2 年）" placeholder-style="color:#6E6A62;"
          value="{{personalInfo.medicationHistory}}" bindinput="bindMedicationHistoryInput" />
      </view>
    </view>

    <view class="form__row">
      <text class="form__label eyebrow">CONTRAINDICATIONS  /  用药禁忌</text>
      <view class="field field--textarea">
        <textarea class="form__textarea serif" placeholder="如：青霉素过敏 / 严重肾功能不全" placeholder-style="color:#6E6A62;"
          value="{{personalInfo.medicationContraindications}}" bindinput="bindMedicationContraindicationsInput" />
      </view>
    </view>

    <button class="btn btn--primary" style="margin-top: 40rpx;" bindtap="handleSave">保  存  档  案</button>
  </view>

  <view wx:if="{{statusTip}}" class="toast-pill">{{statusTip}}</view>
</view>
