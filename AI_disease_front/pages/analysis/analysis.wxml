<view class="container">
  <!-- 分析标题 -->
  <view class="analysis-header">
    <text class="analysis-title">慢性病分析</text>
    <text class="analysis-subtitle">最近10条健康记录</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">正在分析数据...</text>
  </view>

  <!-- 无数据状态 -->
  <view wx:elif="{{!loading && !records.length}}" class="empty-container">
    <text class="empty-text">暂无健康数据</text>
    <navigator url="/pages/submit/submit" class="add-btn" open-type="switchTab">添加记录</navigator>
  </view>

  <!-- 分析结果 -->
  <view wx:else class="analysis-content">
    <!-- 统计信息 -->
    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-value">{{averageSystolic}}</text>
        <text class="stat-label">平均收缩压</text>
        <text class="stat-unit">mmHg</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{averageDiastolic}}</text>
        <text class="stat-label">平均舒张压</text>
        <text class="stat-unit">mmHg</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{averageBloodSugar}}</text>
        <text class="stat-label">平均血糖</text>
        <text class="stat-unit">mmol/L</text>
      </view>
    </view>

    <!-- 趋势分析 -->
    <view class="trend-section">
      <text class="section-title">趋势分析</text>
      <view class="trend-card">
        <text class="trend-label">血压趋势</text>
        <text class="trend-value">{{bloodPressureTrend}}</text>
      </view>
      <view class="trend-card">
        <text class="trend-label">血糖趋势</text>
        <text class="trend-value">{{bloodSugarTrend}}</text>
      </view>
    </view>

    <!-- 异常分析 -->
    <view class="abnormal-section">
      <text class="section-title">异常分析</text>
      <view class="abnormal-card">
        <text class="abnormal-label">异常记录数</text>
        <text class="abnormal-value">{{abnormalCount}}</text>
      </view>
      <view class="abnormal-tips" wx:if="{{abnormalTips.length}}">
        <text class="tips-title">注意事项</text>
        <view wx:for="{{abnormalTips}}" wx:key="index" class="tip-item">
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 最近记录 -->
    <view class="records-section">
      <text class="section-title">最近记录</text>
      <view wx:for="{{records}}" wx:key="index" class="record-item">
        <view class="record-header">
          <text class="record-time">{{item.formattedTime}}</text>
        </view>
        <view class="record-data">
          <view class="record-item-data">
            <text class="record-label">血压</text>
            <text class="record-value">{{item.systolic}}/{{item.diastolic}} mmHg</text>
          </view>
          <view class="record-item-data">
            <text class="record-label">血糖</text>
            <text class="record-value">{{item.blood_sugar}} mmol/L</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>