.container { min-height: 100vh; background: var(--bg-base); }

.masthead { margin-bottom: 32rpx; }
.masthead__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero {
  position: relative;
  display: flex;
  align-items: flex-start;
  margin: 16rpx 0 56rpx;
  min-height: 360rpx;
}
.hero__bignum {
  font-family: var(--font-serif);
  font-size: 320rpx;
  line-height: .82;
  color: var(--accent-cool);
  font-weight: 500;
  font-style: italic;
  margin-right: 32rpx;
  text-shadow: 0 4rpx 32rpx rgba(125,211,192,.22);
  letter-spacing: -8rpx;
}
.hero__copy {
  flex: 1;
  padding-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.hero__title {
  font-family: var(--font-serif);
  font-size: 60rpx;
  line-height: 1.05;
  color: var(--ink-strong);
  font-weight: 500;
  letter-spacing: 4rpx;
  white-space: pre-line;
  text-shadow: 0 2rpx 0 var(--line-soft);
}
.hero__desc {
  font-family: var(--font-serif);
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-mid);
  white-space: pre-line;
  margin-top: 8rpx;
  border-left: 2rpx solid var(--accent-cool);
  padding-left: 18rpx;
}

.form { margin-top: 16rpx; }
.form__row { margin-bottom: 28rpx; }
.form__label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--ink-dim);
}
.form__input {
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  color: var(--ink-strong);
  font-size: 30rpx;
}

.links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14rpx;
  margin-top: 36rpx;
}
.links__hint { font-size: 24rpx; color: var(--ink-dim); }
.links__action {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--accent-cool);
  letter-spacing: 2rpx;
}

.footnote { margin-top: 80rpx; text-align: center; }
